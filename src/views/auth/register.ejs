<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar — File Vault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="auth-page">

    <a href="/" class="auth-logo">
      <div class="logo-icon">🗂️</div>
      File Vault
    </a>

    <div class="card--auth" style="max-width:420px;width:100%;">
      <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:0.35rem;">Buat akun baru</h1>
      <p class="text-sm text-muted" style="margin-bottom:1.75rem;">Simpan dan kelola file Anda dengan aman</p>

      <% if (error) { %>
        <div class="alert alert--error">
          <span>⚠️</span> <%= error %>
        </div>
      <% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="nama@email.com" required autocomplete="email">
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" type="password" id="password" name="password" placeholder="Min. 8 karakter" required autocomplete="new-password">
        </div>

        <button type="submit" class="btn btn--primary btn--full" style="padding:0.75rem;">
          Buat Akun
        </button>
      </form>

      <div class="divider"></div>

      <p class="text-sm text-muted" style="text-align:center;">
        Sudah punya akun?
        <a href="/login" style="color:var(--color-primary);text-decoration:none;font-weight:500;">Masuk</a>
      </p>
    </div>

  </div>
</body>
</html>