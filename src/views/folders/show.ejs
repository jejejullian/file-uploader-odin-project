<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= folder.name %> — File Vault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-wrapper">

  <header class="site-header">
    <div class="container inner">
      <a href="/" class="logo">
        <div class="logo-icon">🗂️</div>
        File Vault
      </a>
    </div>
  </header>

  <main>
    <div class="container">

      <nav class="breadcrumb">
        <a href="/">Dashboard</a>
        <span class="breadcrumb-sep">›</span>
        <span><%= folder.name %></span>
      </nav>

      <!-- Folder Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div style="font-size:2rem;">📁</div>
          <div>
            <h1 class="page-title"><%= folder.name %></h1>
            <p class="page-subtitle" style="margin-bottom:0;">
              <%= folder.files ? folder.files.length : 0 %> file
            </p>
          </div>
        </div>
        <div class="flex gap-2">
          <a href="/folders/<%= folder.id %>/edit" class="btn btn--ghost btn--sm">✏️ Edit</a>
        </div>
      </div>

      <!-- Upload Zone -->
      <div class="card mb-6">
        <p class="section-title">Upload File Baru</p>
        <form action="/files/upload" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="folderId" value="<%= folder.id %>">
          <div class="upload-zone">
            <div class="upload-zone-icon">📤</div>
            <p class="upload-zone-text">Pilih file untuk diupload ke folder ini</p>
            <input class="form-input" type="file" name="file_uploader" required style="max-width:300px;margin:0 auto 1rem;">
            <br>
            <button type="submit" class="btn btn--primary">Upload File</button>
          </div>
        </form>
      </div>

      <!-- File List -->
      <div class="card mb-6">
        <p class="section-title">Daftar File</p>
        <% if (folder.files && folder.files.length > 0) { %>
          <div class="file-list">
            <% folder.files.forEach(file => { %>
              <div class="file-item">
                <div class="file-icon">📄</div>
                <div class="file-info">
                  <a href="/files/<%= file.id %>" class="file-name"><%= file.name %></a>
                  <div class="file-size"><%= (file.size / 1024).toFixed(2) %> KB</div>
                </div>
                <div class="file-actions">
                  <form action="/files/<%= file.id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Hapus file ini?')">
                    <button type="submit" class="btn btn--danger btn--sm">🗑️ Hapus</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state" style="padding:2.5rem 1rem;">
            <div class="empty-state-icon">📄</div>
            <div class="empty-state-title">Folder masih kosong</div>
            <div class="empty-state-desc">Upload file pertama Anda di atas</div>
          </div>
        <% } %>
      </div>

      <!-- Share Folder -->
      <div class="share-box">
        <p class="section-title">🔗 Bagikan Folder</p>
        <form action="/folders/<%= folder.id %>/share" method="POST">
          <div class="flex items-center gap-3">
            <div class="form-group" style="flex:1;margin-bottom:0;">
              <label class="form-label" for="duration">Masa berlaku link</label>
              <select class="form-input" name="duration" id="duration" required>
                <option value="1">1 Hari</option>
                <option value="3">3 Hari</option>
                <option value="7">7 Hari</option>
                <option value="10">10 Hari</option>
              </select>
            </div>
            <div style="margin-top:1.25rem;">
              <button type="submit" class="btn btn--primary">Generate Link</button>
            </div>
          </div>
        </form>

        <% if (folder.shareLinks && folder.shareLinks.length > 0) { %>
          <div class="mt-4">
            <p class="text-xs text-muted font-semibold mb-2">Link Aktif:</p>
            <% folder.shareLinks.forEach(link => { %>
              <div class="share-link-row">
                <input class="share-link-input" type="text" readonly
                  value="http://localhost:3000/share/<%= link.id %>"
                  onclick="this.select()">
                <button type="button" class="btn btn--ghost btn--sm"
                  onclick="navigator.clipboard.writeText('http://localhost:3000/share/<%= link.id %>')">
                  📋
                </button>
              </div>
              <p class="share-link-expire">Berakhir: <%= link.expiresAt.toLocaleString('id-ID') %></p>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>
  </main>

</body>
</html>