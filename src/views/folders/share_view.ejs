<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Berbagi: <%= folder.name %> — File Vault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-wrapper">

  <header class="site-header">
    <div class="container inner">
      <a href="/" class="logo">
        <div class="logo-icon">🗂️</div>
        File Vault
      </a>
      <span class="badge badge--primary">Tautan Publik</span>
    </div>
  </header>

  <main>
    <div class="container" style="max-width:720px;">

      <!-- Folder Info -->
      <div class="card mb-6" style="text-align:center;padding:2.5rem;">
        <div style="font-size:3rem;margin-bottom:1rem;">📁</div>
        <h1 class="page-title"><%= folder.name %></h1>
        <p class="page-subtitle" style="margin-bottom:0;">
          Anda melihat folder ini melalui tautan berbagi publik
        </p>
        <div class="divider"></div>
        <p class="text-xs text-muted">
          🔒 Tautan ini bersifat sementara dan hanya bisa digunakan untuk mengunduh
        </p>
      </div>

      <!-- File List -->
      <div class="card">
        <p class="section-title">📄 Daftar File</p>
        <% if (folder.files && folder.files.length > 0) { %>
          <div class="file-list">
            <% folder.files.forEach(file => { %>
              <div class="file-item">
                <div class="file-icon">📄</div>
                <div class="file-info">
                  <span class="file-name"><%= file.name %></span>
                  <div class="file-size"><%= (file.size / 1024).toFixed(2) %> KB</div>
                </div>
                <div class="file-actions">
                  <a href="<%= file.url %>" download="<%= file.name %>"
                    class="btn btn--primary btn--sm">
                    ⬇️ Download
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state" style="padding:2.5rem 1rem;">
            <div class="empty-state-icon">📭</div>
            <div class="empty-state-title">Folder ini kosong</div>
          </div>
        <% } %>
      </div>

    </div>
  </main>

  <footer style="text-align:center;padding:1.5rem;color:var(--text-muted);font-size:0.75rem;border-top:1px solid var(--border-subtle);margin-top:2rem;">
    Dibagikan via <strong style="color:var(--text-secondary);">File Vault</strong> · Tautan bersifat sementara
  </footer>

</body>
</html>