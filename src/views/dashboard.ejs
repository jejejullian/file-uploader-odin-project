<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — File Vault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-wrapper">

  <!-- HEADER -->
  <header class="site-header">
    <div class="container inner">
      <a href="/" class="logo">
        <div class="logo-icon">🗂️</div>
        File Vault
      </a>
      <div class="nav-actions">
        <span class="user-badge">📧 <%= user.email %></span>
        <a href="/logout" class="btn btn--ghost btn--sm">Logout</a>
      </div>
    </div>
  </header>

  <!-- MAIN -->
  <main>
    <div class="container">

      <!-- Page heading -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="page-title">My Folders</h1>
          <p class="page-subtitle">Kelola folder dan file Anda</p>
        </div>
        <a href="/folders/create" class="btn btn--primary">
          <span>＋</span> New Folder
        </a>
      </div>

      <!-- Folder grid -->
      <% if (typeof folders !== 'undefined' && folders.length > 0) { %>
        <div class="grid-folders">
          <% folders.forEach(folder => { %>
            <div class="folder-card">
              <div class="folder-icon">📁</div>
              <div>
                <div class="folder-name"><%= folder.name %></div>
                <div class="folder-meta">Dibuat <%= folder.createdAt.toDateString() %></div>
              </div>
              <div class="folder-actions">
                <a href="/folders/<%= folder.id %>" class="btn btn--secondary btn--sm" style="flex:1;justify-content:center;">
                  Buka
                </a>
                <a href="/folders/<%= folder.id %>/edit" class="btn btn--ghost btn--icon" title="Edit">✏️</a>
                <form action="/folders/<%= folder.id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Yakin ingin menghapus folder ini?')">
                  <button type="submit" class="btn btn--danger btn--icon" title="Hapus">🗑️</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">📂</div>
          <div class="empty-state-title">Belum ada folder</div>
          <div class="empty-state-desc">Buat folder pertama Anda untuk mulai menyimpan file</div>
          <a href="/folders/create" class="btn btn--primary mt-4">
            ＋ Buat Folder Pertama
          </a>
        </div>
      <% } %>

    </div>
  </main>

</body>
</html>
